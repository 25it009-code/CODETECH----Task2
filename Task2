<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personal Portfolio</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, sans-serif;
        }

        body{
            background:#f4f4f4;
            color:#333;
        }

        header{
            background:#222;
            color:white;
            padding:20px 0;
            text-align:center;
        }

        nav{
            margin-top:10px;
        }

        nav a{
            color:white;
            text-decoration:none;
            margin:0 15px;
            font-size:18px;
        }

        nav a:hover{
            color:yellow;
        }

        .hero{
            height:90vh;
            display:flex;
            flex-direction:column;
            justify-content:center;
            align-items:center;
            background:linear-gradient(to right, #007bff, #00c6ff);
            color:white;
            text-align:center;
        }

        .hero h1{
            font-size:50px;
        }

        .hero p{
            margin-top:10px;
            font-size:22px;
        }

        .btn{
            margin-top:20px;
            padding:12px 25px;
            background:white;
            color:#007bff;
            border:none;
            border-radius:5px;
            font-size:18px;
            cursor:pointer;
            text-decoration:none;
        }

        .btn:hover{
            background:#222;
            color:white;
        }

        section{
            padding:60px 20px;
            max-width:1000px;
            margin:auto;
        }

        h2{
            text-align:center;
            margin-bottom:30px;
            color:#007bff;
        }

        .about p{
            text-align:center;
            font-size:18px;
            line-height:1.8;
        }

        .skills{
            display:flex;
            justify-content:center;
            flex-wrap:wrap;
            gap:15px;
        }

        .skill{
            background:#007bff;
            color:white;
            padding:15px 25px;
            border-radius:8px;
            font-size:18px;
        }

        .projects{
            display:grid;
            grid-template-columns:repeat(auto-fit, minmax(250px,1fr));
            gap:20px;
        }

        .project-card{
            background:white;
            padding:20px;
            border-radius:10px;
            box-shadow:0 0 10px rgba(0,0,0,0.1);
        }

        .project-card h3{
            margin-bottom:10px;
        }

        .contact{
            text-align:center;
        }

        .contact p{
            margin:10px 0;
            font-size:18px;
        }

        footer{
            background:#222;
            color:white;
            text-align:center;
            padding:15px;
            margin-top:30px;
        }

    </style>

</head>

<body>

    <header>
        <h1>My Portfolio</h1>

        <nav>
            <a href="#about">About</a>
            <a href="#skills">Skills</a>
            <a href="#projects">Projects</a>
            <a href="#contact">Contact</a>
        </nav>
    </header>

    <section class="hero">
        <h1>Hello, I'm Archana</h1>
        <p>Web Developer | Student | Programmer</p>

        <a href="#projects" class="btn">View Projects</a>
    </section>

    <section id="about" class="about">
        <h2>About Me</h2>

        <p>
            I am a passionate web developer and programming student.
            I love creating websites and learning new technologies.
            My goal is to become a successful software developer.
        </p>
    </section>

    <section id="skills">
        <h2>My Skills</h2>

        <div class="skills">
            <div class="skill">HTML</div>
            <div class="skill">CSS</div>
            <div class="skill">JavaScript</div>
            <div class="skill">Java</div>
            <div class="skill">C++</div>
            <div class="skill">Python</div>
        </div>
    </section>

    <section id="projects">
        <h2>Projects</h2>

        <div class="projects">

            <div class="project-card">
                <h3>Personal Finance Tracker</h3>
                <p>Track income and expenses using HTML, CSS, and JavaScript.</p>
            </div>

            <div class="project-card">
                <h3>Student Management System</h3>
                <p>Manage student details and records easily.</p>
            </div>

            <div class="project-card">
                <h3>Weather App</h3>
                <p>Displays weather information using API integration.</p>
            </div>

        </div>
    </section>

    <section id="contact" class="contact">
        <h2>Contact Me</h2>

        <p>Email: archana@example.com</p>
        <p>Phone: +91 9876543210</p>
        <p>Location: Tamil Nadu, India</p>
    </section>

    <footer>
        <p>© 2026 My Portfolio | All Rights Reserved</p>
    </footer>

</body>
</html>
